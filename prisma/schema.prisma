generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINAL
}

enum SurvivorStatus {
  ALIVE
  ELIMINATED
}

enum PickOutcome {
  PENDING
  WON
  LOST
  MISSED
}

enum ChallengeDifficulty {
  LOW
  MEDIUM
  HIGH
}

enum ChallengeType {
  BOTH_TEAMS_SCORE
  OVER_25_GOALS
  RED_CARD_YES_NO
  MATCH_WITH_MOST_GOALS
  UNDERDOG_AVOIDS_DEFEAT
}

enum ChallengeState {
  OPEN
  LOCKED
  SETTLED
}

enum BadgeCategory {
  SURVIVAL
  CHALLENGE
  MILESTONE
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  username           String             @unique
  favoriteNation     String?
  bio                String?
  streakGoal         Int                @default(10)
  survivorPoints     Int                @default(0)
  challengeBonusPoints Int              @default(0)
  currentStreak      Int                @default(0)
  longestStreak      Int                @default(0)
  survivorStatus     SurvivorStatus     @default(ALIVE)
  eliminatedAt       DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  picks              Pick[]
  challengeAnswers   ChallengeAnswer[]
  badges             UserBadge[]
  stats              UserStats?
}

model Matchday {
  id          String   @id @default(cuid())
  slug        String   @unique
  order       Int      @unique
  title       String
  closesAt    DateTime
  settledAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  matches     Match[]
  picks       Pick[]
  challenges  Challenge[]
}

model Match {
  id              String      @id @default(cuid())
  externalId      String?     @unique
  matchdayId      String
  homeTeam        String
  awayTeam        String
  venue           String
  kickoffAt       DateTime
  status          MatchStatus @default(SCHEDULED)
  winner          String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  matchday        Matchday    @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  picks           Pick[]
  challenges      Challenge[]
}

model Pick {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  matchdayId    String
  selectedTeam  String
  confidence    Int
  lockedAt      DateTime?
  outcome       PickOutcome @default(PENDING)
  pointsAwarded Int         @default(0)
  settledAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchday      Matchday @relation(fields: [matchdayId], references: [id], onDelete: Cascade)

  @@unique([userId, matchdayId])
  @@index([userId, selectedTeam])
}

model Challenge {
  id              String              @id @default(cuid())
  matchdayId       String
  matchId          String?
  slug             String              @unique
  title            String
  description      String
  type             ChallengeType
  difficulty       ChallengeDifficulty
  state            ChallengeState      @default(OPEN)
  bonusPoints      Int
  lockAt           DateTime
  settledAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  matchday         Matchday            @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  match            Match?              @relation(fields: [matchId], references: [id], onDelete: SetNull)
  options          ChallengeOption[]
  answers          ChallengeAnswer[]
}

model ChallengeOption {
  id              String          @id @default(cuid())
  challengeId     String
  label           String
  value           String
  sortOrder       Int             @default(0)
  isCorrect       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  challenge       Challenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  answers         ChallengeAnswer[]

  @@unique([challengeId, value])
}

model ChallengeAnswer {
  id                String           @id @default(cuid())
  challengeId       String
  challengeOptionId String
  userId            String
  bonusPointsAwarded Int             @default(0)
  isCorrect         Boolean?
  submittedAt       DateTime         @default(now())
  settledAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  challenge         Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  challengeOption   ChallengeOption  @relation(fields: [challengeOptionId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model Badge {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  description   String
  icon          String
  category      BadgeCategory
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userBadges    UserBadge[]
}

model UserBadge {
  id            String      @id @default(cuid())
  userId        String
  badgeId       String
  awardedAt     DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge         Badge       @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model UserStats {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  totalPicks             Int      @default(0)
  settledPicks           Int      @default(0)
  survivorWins           Int      @default(0)
  survivorLosses         Int      @default(0)
  totalChallengeAnswers  Int      @default(0)
  correctChallengeAnswers Int     @default(0)
  currentSurvivalStreak  Int      @default(0)
  longestSurvivalStreak  Int      @default(0)
  currentChallengeStreak Int      @default(0)
  longestChallengeStreak Int      @default(0)
  totalPoints            Int      @default(0)
  totalBonusPoints       Int      @default(0)
  badgesUnlocked         Int      @default(0)
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

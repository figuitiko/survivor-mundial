generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINAL
}

enum ChallengeDifficulty {
  LOW
  MEDIUM
  HIGH
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  username           String             @unique
  favoriteNation     String?
  bio                String?
  streakGoal         Int                @default(10)
  survivorPoints     Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  picks              Pick[]
  challengeEntries   ChallengeEntry[]
}

model Matchday {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  closesAt    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  matches     Match[]
  challenges  StatChallenge[]
}

model Match {
  id              String      @id @default(cuid())
  externalId      String?     @unique
  matchdayId      String
  homeTeam        String
  awayTeam        String
  venue           String
  kickoffAt       DateTime
  status          MatchStatus @default(SCHEDULED)
  winner          String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  matchday        Matchday    @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  picks           Pick[]
}

model Pick {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  selectedTeam  String
  confidence    Int
  lockedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model StatChallenge {
  id            String               @id @default(cuid())
  matchdayId    String
  slug          String               @unique
  title         String
  description   String
  rewardPoints  Int
  difficulty    ChallengeDifficulty
  closesAt      DateTime
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  matchday      Matchday             @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  entries       ChallengeEntry[]
}

model ChallengeEntry {
  id              String        @id @default(cuid())
  userId          String
  statChallengeId String
  prediction      String
  pointsAwarded   Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  statChallenge   StatChallenge @relation(fields: [statChallengeId], references: [id], onDelete: Cascade)

  @@unique([userId, statChallengeId])
}
